{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.ts",
  "scripts": {
    "predev": "cd ../shared && npm run build",
    "dev": "tsx watch src/server.ts",
    "prebuild": "cd ../shared && npm run build",
    "build": "tsc",
    "test": "tsx tests/sim.test.ts",
    "test:unit": "tsx tests/unit/analyticsEngine.test.ts && tsx tests/unit/playbookEngine.test.ts",
    "test:integration": "tsx tests/integration/api.test.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/compress": "^9.1.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "shared": "file:../shared",
    "socket.io": "^4.7.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2"
  }
}
